<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="App.FingerprintLabPage"
             Title="Fingerprint Lab"
             >
    <VerticalStackLayout Padding="16" Spacing="12">

        <Label Text="Live Scan" FontAttributes="Bold"/>

        <Button Text="Start"
                Clicked="OnStartClicked"/>

        <Button Text="Stop"
                Clicked="OnStopClicked"/>

        <Label Text="Current Fingerprint"
               FontAttributes="Bold"/>

        <ScrollView HeightRequest="400">
            <Label x:Name="FingerprintLabel"
                   FontFamily="Courier"
                   FontSize="12"/>
        </ScrollView>

    </VerticalStackLayout>
</ContentPage>