{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Action Sequence",
  "description": "A sequential list of actions.",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["action"],
    "properties": {
      "action": {
        "type": "string",
        "enum": ["walk", "turn", "stop", "lifting", "stairs"]
      }
    },
    "allOf": [
      {
        "if": { "properties": { "action": { "const": "walk" } } },
        "then": {
          "properties": {
            "steps": { "type": "integer", "minimum": 1 },
            "duration": { "type": "number", "description": "Duration in seconds" }
          },
          "required": ["steps", "duration"]
        }
      },
      {
        "if": { "properties": { "action": { "const": "turn" } } },
        "then": {
          "properties": {
            "direction": { "type": "string", "enum": ["left", "right", "little left", "little right", "around"] }
          },
          "required": ["direction"]
        }
      },
      {
        "if": { "properties": { "action": { "const": "stop" } } },
        "then": {
          "properties": {
            "duration": { "type": "number", "description": "Duration in seconds" }
          },
          "required": ["duration"]
        }
      },
      {
        "if": { "properties": { "action": { "const": "lifting" } } },
        "then": {
          "properties": {
            "from": { "type": "integer", "description": "Starting height (integer only)" },
            "to": { "type": "integer", "description": "Target height (integer only)" },
            "duration": { "type": "number", "description": "Duration in seconds" }
          },
          "required": ["from", "to", "duration"]
        }
      },
      {
        "if": { "properties": { "action": { "const": "stairs" } } },
        "then": {
          "properties": {
            "direction": { "type": "string", "enum": ["up", "down"] },
            "duration": { "type": "number", "description": "Duration in seconds" }
          },
          "required": ["direction", "duration"]
        }
      }
    ]
  }
}
