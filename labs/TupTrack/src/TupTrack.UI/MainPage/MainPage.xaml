<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TupTrack.UI.MainPage.MainPage" 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="Black"
    Shell.NavBarIsVisible="False"
    
    xmlns:components="clr-namespace:TupTrack.UI.MainPage"
    
    >

    <!-- x:Class  linking C# code-behind with this XAML page
        xmlns XML namespace - gives buttons and etc
        xmlns:x gets another namespacs and makes x allias for it. For exampl it has x:Class for linking.
        compnents is my namespace with my commponnets
    -->

    <ContentPage.Resources>
        <Color x:Key="SurfaceBrown">#3D3226</Color>
        <Color x:Key="TextWhite">White</Color>

        <Style x:Key="MatrixButtonStyle" TargetType="Button">
            <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="FontSize" Value="25" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HeightRequest" Value="62" />
            <Setter Property="BorderWidth" Value="0" />
        </Style>

        <Style x:Key="RoomButtonStyle" TargetType="Button" BasedOn="{StaticResource MatrixButtonStyle}">
            <Setter Property="BackgroundColor" Value="{StaticResource SurfaceBrown}" />
        </Style>


    </ContentPage.Resources>
    
    
    

    <Grid
        Padding="24,0,24,0"
        RowDefinitions="Auto,76,Auto,Auto,*,Auto"
        RowSpacing="18">

        <!-- Stop Recording -->
        <Button
            x:Name="StopRecordingButton"
            Grid.Row="0"
            WidthRequest="56"
            HeightRequest="56"
            CornerRadius="28"
            BackgroundColor="#FF1919"
            HorizontalOptions="End"
            Opacity="1"
            Clicked="OnStopRecordingClicked" />
    
        <!-- Start Recording Button with info -->
        <Grid Grid.Row="1" HeightRequest="76">
            <Button
                x:Name="StartRecordingButton"
                Text="Start Recording"
                HorizontalOptions="Center"
                WidthRequest="290"
                HeightRequest="76"
                CornerRadius="38"
                FontAttributes="Bold"
                FontSize="40"
                TextColor="{StaticResource TextWhite}"
                BackgroundColor="#31C95E"
                Clicked="OnStartRecordingClicked" />

            <VerticalStackLayout
                x:Name="RecordingInfoView"
                IsVisible="False"
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Spacing="4"
                WidthRequest="290">
                <Label
                    x:Name="RecordingTimeLabel"
                    Text="00:00"
                    FontSize="46"
                    FontAttributes="Bold"
                    TextColor="{StaticResource TextWhite}"
                    HorizontalTextAlignment="Center" />

                <components:LabelsBar
                    x:Name="RecordingTopBar"
                    BarHeight="3"
                    HorizontalOptions="Fill" />

                <components:LabelsBar
                    x:Name="RecordingBottomBar"
                    BarHeight="3"
                    HorizontalOptions="Fill" />
            </VerticalStackLayout>
        </Grid>


        <!-- Buttons Grid -->
        <components:ButtonsGrid Grid.Row="2" />

        <components:MetaDataButtons Grid.Row ="3"/>


    </Grid>   
</ContentPage>
