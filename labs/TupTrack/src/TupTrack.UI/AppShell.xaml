<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TupTrack.UI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mainPage="clr-namespace:TupTrack.UI.MainPage"
    xmlns:statistics="clr-namespace:TupTrack.UI.StatisticsPage"
    Title="TupTrack.UI">

    <TabBar>
        <Tab Title="Home" >
            <ShellContent
            ContentTemplate="{DataTemplate mainPage:MainPage}"
            Route="MainPage" />
        </Tab>

        <Tab Title="Staistics">
            <ShellContent
            ContentTemplate="{DataTemplate statistics:StatisticsPage}"
            Route="SettingsPage" />
        </Tab>
    </TabBar>

</Shell>
